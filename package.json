{
  "name": "chronos",
  "version": "1.0.0",
  "private": true,
  "description": "Chronos Enterprise Workspace (Monorepo)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w web\" \"npm run dev -w api\"",
    "build": "npm run build --workspaces --if-present",
    "db:push": "npm run db:push -w api",
    "db:studio": "npm run db:studio -w api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}